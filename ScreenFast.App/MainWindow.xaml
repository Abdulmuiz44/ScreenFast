<Window
    x:Class="ScreenFast.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:ScreenFast.App.ViewModels"
    mc:Ignorable="d">

    <Grid Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="#111827">
            <Grid Padding="24,28" RowSpacing="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock Foreground="White" FontSize="30" FontWeight="SemiBold" Text="ScreenFast" />
                    <TextBlock Foreground="#CBD5E1" FontSize="14" Text="Native recording workflow" />
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="6">
                    <Border Padding="10,7" Background="#1E5A7A" BorderBrush="#38BDF8" BorderThickness="1" CornerRadius="2">
                        <TextBlock Foreground="White" FontSize="16" Text="Dashboard" />
                    </Border>
                    <TextBlock Margin="10,6,0,0" Foreground="White" FontSize="16" Text="Recent Recordings" />
                    <TextBlock Margin="10,6,0,0" Foreground="White" FontSize="16" Text="Settings" />
                    <TextBlock Margin="10,6,0,0" Foreground="White" FontSize="16" Text="Diagnostics" />
                </StackPanel>

                <StackPanel Grid.Row="3" Spacing="8">
                    <TextBlock Foreground="#CBD5E1" Text="Status" />
                    <TextBlock Foreground="White" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.StateText, Mode=OneWay}" />
                    <TextBlock Foreground="#CBD5E1" FontFamily="Consolas" FontSize="18" Text="{x:Bind ViewModel.TimerText, Mode=OneWay}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Padding="28" RowSpacing="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Padding="24,18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock VerticalAlignment="Center" FontSize="22" FontWeight="SemiBold" Text="Recorder Status" />
                    <Border Grid.Column="1" Padding="10,5" Background="{ThemeResource AccentFillColorTertiaryBrush}" CornerRadius="6">
                        <TextBlock Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
                    </Border>
                    <TextBlock Grid.Column="2"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="WrapWholeWords"
                               Text="{x:Bind ViewModel.ShellMessageText, Mode=OneWay}" />
                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="10">
                        <TextBlock VerticalAlignment="Center" FontFamily="Consolas" FontSize="18" FontWeight="SemiBold" Text="{x:Bind ViewModel.TimerText, Mode=OneWay}" />
                        <TextBlock VerticalAlignment="Center" Foreground="IndianRed" FontSize="18" FontWeight="SemiBold" Text="{x:Bind ViewModel.CountdownText, Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Grid.Row="1" Spacing="8">
                <InfoBar IsOpen="{x:Bind ViewModel.IsOnboardingVisible, Mode=OneWay}"
                         Severity="Informational"
                         IsClosable="False"
                         Message="Select a source, choose an output folder, confirm quality and audio, then record. MP4 finalization remains the primary success path.">
                    <InfoBar.ActionButton>
                        <Button Command="{x:Bind ViewModel.DismissOnboardingCommand}" Content="Got it" />
                    </InfoBar.ActionButton>
                </InfoBar>

                <InfoBar Title="Previous recording may have ended unexpectedly"
                         IsOpen="{x:Bind ViewModel.IsRecoveryNoticeVisible, Mode=OneWay}"
                         Severity="Warning"
                         IsClosable="False"
                         Message="{x:Bind ViewModel.RecoveryNoticeText, Mode=OneWay}">
                    <InfoBar.ActionButton>
                        <Button Content="Recovery Actions">
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Open Folder" Command="{x:Bind ViewModel.OpenRecoveryFolderCommand}" />
                                    <MenuFlyoutItem Text="Copy Path" Command="{x:Bind ViewModel.CopyRecoveryPathCommand}" />
                                    <MenuFlyoutItem Text="Clear" Command="{x:Bind ViewModel.ClearRecoveryStateCommand}" />
                                    <MenuFlyoutItem Text="Dismiss" Command="{x:Bind ViewModel.DismissRecoveryNoticeCommand}" />
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </InfoBar.ActionButton>
                </InfoBar>

                <InfoBar IsOpen="{x:Bind ViewModel.HasDiskSpaceWarning, Mode=OneWay}"
                         Severity="Warning"
                         IsClosable="False"
                         Message="{x:Bind ViewModel.DiskSpaceWarningText, Mode=OneWay}" />
            </StackPanel>

            <TabView Grid.Row="2" IsAddTabButtonVisible="False" CanDragTabs="False">
                <TabViewItem Header="Dashboard" IsClosable="False">
                    <ScrollViewer>
                        <Grid Padding="28" RowSpacing="16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid ColumnSpacing="16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button MinWidth="150" MinHeight="38" Command="{x:Bind ViewModel.SelectSourceCommand}" Content="Select Source" />
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Capture Source" />
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SourceSummary, Mode=OneWay}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.SourceDetails, Mode=OneWay}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.SourceIdText, Mode=OneWay}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <Border Grid.Column="1" Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                                    <Grid ColumnSpacing="16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Button MinWidth="170" MinHeight="38" Command="{x:Bind ViewModel.PickOutputFolderCommand}" Content="Output Folder" />
                                        <StackPanel Grid.Column="1" Spacing="4">
                                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Output" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.OutputFolderText, Mode=OneWay}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>

                            <Border Grid.Row="1" Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                                <StackPanel Spacing="14">
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Recording Setup" />
                                    <Grid ColumnSpacing="16" RowSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="240" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Quality" />
                                        <ComboBox Grid.Column="1" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.QualityPresets, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedQualityPreset, Mode=TwoWay}" />
                                        <ToggleSwitch Grid.Column="2" Header="System Audio" IsOn="{x:Bind ViewModel.IncludeSystemAudio, Mode=TwoWay}" />
                                        <ToggleSwitch Grid.Column="3" Header="Microphone" IsOn="{x:Bind ViewModel.IncludeMicrophone, Mode=TwoWay}" />

                                        <TextBlock Grid.Row="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="Countdown" />
                                        <ComboBox Grid.Row="1" Grid.Column="1" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.CountdownOptions, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedCountdownOption, Mode=TwoWay}" />
                                        <ToggleSwitch Grid.Row="1" Grid.Column="2" Header="Overlay" IsOn="{x:Bind ViewModel.OverlayEnabled, Mode=TwoWay}" />

                                        <TextBlock Grid.Row="2" VerticalAlignment="Center" FontWeight="SemiBold" Text="After Stop" />
                                        <ComboBox Grid.Row="2" Grid.Column="1" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.PostRecordingBehaviors, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedPostRecordingBehavior, Mode=TwoWay}" />
                                        <Button Grid.Row="2" Grid.Column="2" MinHeight="38" Command="{x:Bind ViewModel.ShowOnboardingAgainCommand}" Content="Show onboarding" />
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <Border Grid.Row="2" Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                                <Grid ColumnSpacing="16">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Button MinWidth="120" MinHeight="40" Command="{x:Bind ViewModel.RecordCommand}" Content="Record" />
                                    <Button Grid.Column="1" MinWidth="120" MinHeight="40" Command="{x:Bind ViewModel.PauseResumeCommand}" Content="{x:Bind ViewModel.PauseResumeText, Mode=OneWay}" />
                                    <Button Grid.Column="2" MinWidth="120" MinHeight="40" Command="{x:Bind ViewModel.StopCommand}" Content="Stop" />

                                    <StackPanel Grid.Column="3" Spacing="4">
                                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Ready Check" />
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.ReadySourceText, Mode=OneWay}" />
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.ReadyOutputFolderText, Mode=OneWay}" />
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.AudioChoicesSummary, Mode=OneWay}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Grid.Row="3" Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                                <StackPanel Spacing="6">
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Startup Checks" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.SmokeCheckSummaryText, Mode=OneWay}" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.SmokeCheckDetailsText, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabViewItem>

                <TabViewItem Header="Recent Recordings" IsClosable="False">
                    <Grid Padding="28" RowSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <StackPanel Spacing="4">
                            <TextBlock FontSize="24" FontWeight="SemiBold" Text="Recent Recordings" />
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.RecentRecordingsStatusText, Mode=OneWay}" />
                        </StackPanel>

                        <ListView Grid.Row="1"
                                  Background="Transparent"
                                  ItemsSource="{x:Bind ViewModel.RecentRecordings, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedRecentRecording, Mode=TwoWay}">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="viewModels:RecordingHistoryItemViewModel">
                                    <Border Margin="0,4,0,6" Padding="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                                        <StackPanel Spacing="4">
                                            <TextBlock FontWeight="SemiBold" Text="{x:Bind FileName}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind SourceSummary}" />
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind CreatedAtText}" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind DurationText}" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind QualityPreset}" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind MediaFlagsText}" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind FileSizeText}" />
                                                <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind AvailabilityText}" />
                                            </StackPanel>
                                            <TextBlock Foreground="IndianRed" TextWrapping="WrapWholeWords" Text="{x:Bind FailureText}" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <CommandBar Grid.Row="2" DefaultLabelPosition="Right" Background="Transparent">
                            <AppBarButton Label="Open File" Command="{x:Bind ViewModel.OpenRecordingCommand}" />
                            <AppBarButton Label="Open Folder" Command="{x:Bind ViewModel.OpenContainingFolderCommand}" />
                            <AppBarButton Label="Copy Path" Command="{x:Bind ViewModel.CopyPathCommand}" />
                            <AppBarSeparator />
                            <AppBarButton Label="Remove" Command="{x:Bind ViewModel.RemoveHistoryItemCommand}" />
                            <AppBarButton Label="Clear Missing" Command="{x:Bind ViewModel.ClearMissingHistoryCommand}" />
                            <AppBarButton Label="Clear All" Command="{x:Bind ViewModel.ClearAllHistoryCommand}" />
                        </CommandBar>
                    </Grid>
                </TabViewItem>

                <TabViewItem Header="Settings" IsClosable="False">
                    <ScrollViewer>
                        <Grid Padding="28" ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Border Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                                <StackPanel Spacing="12">
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Startup and Tray" />
                                    <ToggleSwitch Header="Launch Minimized" IsOn="{x:Bind ViewModel.LaunchMinimizedToTray, Mode=TwoWay}" />
                                    <ToggleSwitch Header="Close To Tray" IsOn="{x:Bind ViewModel.CloseToTray, Mode=TwoWay}" />
                                    <ToggleSwitch Header="Minimize To Tray" IsOn="{x:Bind ViewModel.MinimizeToTray, Mode=TwoWay}" />
                                    <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.ShellMessageText, Mode=OneWay}" />
                                    <Button MinHeight="38" HorizontalAlignment="Left" Command="{x:Bind ViewModel.ExportDiagnosticsCommand}" Content="Export Diagnostics" />
                                </StackPanel>
                            </Border>

                            <Border Grid.Column="1" Padding="18" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="6">
                                <StackPanel Spacing="12">
                                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Hotkeys" />
                                    <Grid ColumnSpacing="12" RowSpacing="8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="210" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock VerticalAlignment="Center" Text="Start Recording" />
                                        <ComboBox Grid.Column="1" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.HotkeyModifiers, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.StartHotkeyModifier, Mode=TwoWay}" />
                                        <ComboBox Grid.Column="2" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.HotkeyKeys, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.StartHotkeyKey, Mode=TwoWay}" />

                                        <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Stop Recording" />
                                        <ComboBox Grid.Row="1" Grid.Column="1" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.HotkeyModifiers, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.StopHotkeyModifier, Mode=TwoWay}" />
                                        <ComboBox Grid.Row="1" Grid.Column="2" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.HotkeyKeys, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.StopHotkeyKey, Mode=TwoWay}" />

                                        <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="Pause / Resume" />
                                        <ComboBox Grid.Row="2" Grid.Column="1" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.HotkeyModifiers, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.PauseHotkeyModifier, Mode=TwoWay}" />
                                        <ComboBox Grid.Row="2" Grid.Column="2" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.HotkeyKeys, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.PauseHotkeyKey, Mode=TwoWay}" />
                                    </Grid>
                                    <Button Width="130" MinHeight="38" Command="{x:Bind ViewModel.ApplyHotkeysCommand}" Content="Apply Hotkeys" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabViewItem>
            </TabView>
        </Grid>
    </Grid>
</Window>
