<Window
    x:Class="ScreenFast.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:ScreenFast.App.ViewModels"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid MaxWidth="1360" Padding="28" RowSpacing="18" HorizontalAlignment="Center">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Padding="24"
                    Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="20">
                <Grid ColumnSpacing="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Spacing="8">
                        <Border HorizontalAlignment="Left"
                                Padding="10,4"
                                Background="{ThemeResource AccentFillColorSecondaryBrush}"
                                CornerRadius="999">
                            <TextBlock Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                       FontWeight="SemiBold"
                                       Text="Fast desktop capture • MP4 output" />
                        </Border>
                        <TextBlock FontSize="32" FontWeight="SemiBold" Text="ScreenFast" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="WrapWholeWords"
                                   Text="A polished native recorder for capturing screens and windows with system audio, microphone input, hotkeys, recovery, and diagnostics." />
                    </StackPanel>

                    <Border Grid.Column="1"
                            MinWidth="220"
                            Padding="16"
                            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="16">
                        <StackPanel Spacing="6">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Session" />
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="WrapWholeWords"
                                       Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" />
                            <TextBlock FontFamily="Consolas"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="{x:Bind ViewModel.TimerText, Mode=OneWay}" />
                            <TextBlock Foreground="IndianRed"
                                       FontSize="20"
                                       FontWeight="SemiBold"
                                       Text="{x:Bind ViewModel.CountdownText, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <InfoBar Grid.Row="1"
                     IsOpen="{x:Bind ViewModel.IsOnboardingVisible, Mode=OneWay}"
                     Severity="Informational"
                     IsClosable="False"
                     Message="Quick start: select a source, choose an output folder, choose your audio and quality options, then record and stop to finalize MP4.">
                <InfoBar.ActionButton>
                    <Button Command="{x:Bind ViewModel.DismissOnboardingCommand}" Content="Got it" />
                </InfoBar.ActionButton>
            </InfoBar>

            <InfoBar Grid.Row="2"
                     Title="Previous recording may have ended unexpectedly"
                     IsOpen="{x:Bind ViewModel.IsRecoveryNoticeVisible, Mode=OneWay}"
                     Severity="Warning"
                     IsClosable="False"
                     Message="{x:Bind ViewModel.RecoveryNoticeText, Mode=OneWay}">
                <InfoBar.ActionButton>
                    <Button Content="Recovery Actions">
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuFlyoutItem Text="Open Folder"
                                                Command="{x:Bind ViewModel.OpenRecoveryFolderCommand}" />
                                <MenuFlyoutItem Text="Copy Path"
                                                Command="{x:Bind ViewModel.CopyRecoveryPathCommand}" />
                                <MenuFlyoutItem Text="Clear"
                                                Command="{x:Bind ViewModel.ClearRecoveryStateCommand}" />
                                <MenuFlyoutItem Text="Dismiss"
                                                Command="{x:Bind ViewModel.DismissRecoveryNoticeCommand}" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </InfoBar.ActionButton>
            </InfoBar>

            <Border Grid.Row="3"
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button MinWidth="190"
                            MinHeight="40"
                            Padding="18,10"
                            CornerRadius="12"
                            Command="{x:Bind ViewModel.SelectSourceCommand}"
                            Content="Select Source" />

                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Capture Source" />
                        <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SourceSummary, Mode=OneWay}" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.SourceDetails, Mode=OneWay}" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.SourceIdText, Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="4"
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid ColumnSpacing="18">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button MinWidth="190"
                            MinHeight="40"
                            Padding="16,10"
                            CornerRadius="12"
                            Command="{x:Bind ViewModel.PickOutputFolderCommand}"
                            Content="Choose Output Folder" />

                    <StackPanel Grid.Column="1" Spacing="4">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Output" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="WrapWholeWords"
                                   VerticalAlignment="Center"
                                   Text="{x:Bind ViewModel.OutputFolderText, Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="5"
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                <StackPanel Spacing="12">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Recording Setup" />
                    <Grid ColumnSpacing="12" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Quality" />
                        <ComboBox Grid.Column="1"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{x:Bind ViewModel.QualityPresets, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedQualityPreset, Mode=TwoWay}" />
                        <ToggleSwitch Grid.Column="2"
                                      Header="System Audio"
                                      IsOn="{x:Bind ViewModel.IncludeSystemAudio, Mode=TwoWay}" />
                        <ToggleSwitch Grid.Column="3"
                                      Header="Microphone"
                                      IsOn="{x:Bind ViewModel.IncludeMicrophone, Mode=TwoWay}" />

                        <TextBlock Grid.Row="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="Before Recording" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{x:Bind ViewModel.CountdownOptions, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedCountdownOption, Mode=TwoWay}" />
                        <ToggleSwitch Grid.Row="1"
                                      Grid.Column="2"
                                      Header="Overlay"
                                      IsOn="{x:Bind ViewModel.OverlayEnabled, Mode=TwoWay}" />

                        <TextBlock Grid.Row="2" VerticalAlignment="Center" FontWeight="SemiBold" Text="After Recording" />
                        <ComboBox Grid.Row="2"
                                  Grid.Column="1"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{x:Bind ViewModel.PostRecordingBehaviors, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedPostRecordingBehavior, Mode=TwoWay}" />
                        <Button Grid.Row="2"
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                MinHeight="40"
                                Padding="16,10"
                                CornerRadius="12"
                                Command="{x:Bind ViewModel.ShowOnboardingAgainCommand}"
                                Content="Show onboarding" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Row="6"
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Button MinWidth="130"
                            MinHeight="40"
                            Padding="18,10"
                            CornerRadius="12"
                            Command="{x:Bind ViewModel.RecordCommand}"
                            Content="Record" />
                    <Button Grid.Column="1"
                            MinWidth="130"
                            MinHeight="40"
                            Padding="16,10"
                            CornerRadius="12"
                            Command="{x:Bind ViewModel.PauseResumeCommand}"
                            Content="{x:Bind ViewModel.PauseResumeText, Mode=OneWay}" />
                    <Button Grid.Column="2"
                            MinWidth="130"
                            MinHeight="40"
                            Padding="16,10"
                            CornerRadius="12"
                            Command="{x:Bind ViewModel.StopCommand}"
                            Content="Stop" />

                    <Border Grid.Column="3"
                            Padding="12"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="14">
                        <StackPanel Spacing="4">
                            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Ready Check" />
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.ReadySourceText, Mode=OneWay}" />
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.ReadyOutputFolderText, Mode=OneWay}" />
                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.AudioChoicesSummary, Mode=OneWay}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <InfoBar Grid.Row="7"
                     IsOpen="{x:Bind ViewModel.HasDiskSpaceWarning, Mode=OneWay}"
                     Severity="Warning"
                     IsClosable="False"
                     Message="{x:Bind ViewModel.DiskSpaceWarningText, Mode=OneWay}" />

            <Border Grid.Row="8"
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                    <TextBlock FontSize="18"
                               FontWeight="SemiBold"
                               Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                               TextWrapping="WrapWholeWords" />
                    <TextBlock FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="IndianRed"
                               Text="{x:Bind ViewModel.CountdownText, Mode=OneWay}" />
                </StackPanel>
                <TextBlock Grid.Column="1"
                           FontFamily="Consolas"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Text="{x:Bind ViewModel.TimerText, Mode=OneWay}" />
                </Grid>
            </Border>

            <Grid Grid.Row="9" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Padding="18"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <StackPanel Spacing="12">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Startup and Tray" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.SmokeCheckSummaryText, Mode=OneWay}" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.SmokeCheckDetailsText, Mode=OneWay}" />
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <ToggleSwitch Header="Launch Minimized"
                                          IsOn="{x:Bind ViewModel.LaunchMinimizedToTray, Mode=TwoWay}" />
                            <ToggleSwitch Header="Close To Tray"
                                          IsOn="{x:Bind ViewModel.CloseToTray, Mode=TwoWay}" />
                            <ToggleSwitch Header="Minimize To Tray"
                                          IsOn="{x:Bind ViewModel.MinimizeToTray, Mode=TwoWay}" />
                        </StackPanel>
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.StateText, Mode=OneWay}" />
                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.ShellMessageText, Mode=OneWay}" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button MinHeight="40" Padding="16,10" CornerRadius="12" Command="{x:Bind ViewModel.ExportDiagnosticsCommand}" Content="Export Diagnostics" />
                            <TextBlock VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="Exports recent logs and safe app metadata into a zip file." />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="18"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="16">
                    <StackPanel Spacing="12">
                        <TextBlock FontSize="18" FontWeight="SemiBold" Text="Hotkeys" />
                        <Grid ColumnSpacing="12" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock VerticalAlignment="Center" Text="Start Recording" />
                            <ComboBox Grid.Column="1"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.HotkeyModifiers, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.StartHotkeyModifier, Mode=TwoWay}" />
                            <ComboBox Grid.Column="2"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.HotkeyKeys, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.StartHotkeyKey, Mode=TwoWay}" />

                            <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Stop Recording" />
                            <ComboBox Grid.Row="1"
                                      Grid.Column="1"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.HotkeyModifiers, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.StopHotkeyModifier, Mode=TwoWay}" />
                            <ComboBox Grid.Row="1"
                                      Grid.Column="2"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.HotkeyKeys, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.StopHotkeyKey, Mode=TwoWay}" />

                            <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="Pause / Resume" />
                            <ComboBox Grid.Row="2"
                                      Grid.Column="1"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.HotkeyModifiers, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.PauseHotkeyModifier, Mode=TwoWay}" />
                            <ComboBox Grid.Row="2"
                                      Grid.Column="2"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.HotkeyKeys, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.PauseHotkeyKey, Mode=TwoWay}" />
                        </Grid>

                        <Button Width="140"
                                MinHeight="40"
                                Padding="16,10"
                                CornerRadius="12"
                                Command="{x:Bind ViewModel.ApplyHotkeysCommand}"
                                Content="Apply Hotkeys" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="10"
                    Padding="18"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="16">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Recent Recordings" />
                    <TextBlock Grid.Row="1" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind ViewModel.RecentRecordingsStatusText, Mode=OneWay}" />

                    <ListView Grid.Row="2"
                              MinHeight="240"
                              Background="Transparent"
                              ItemsSource="{x:Bind ViewModel.RecentRecordings, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedRecentRecording, Mode=TwoWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:RecordingHistoryItemViewModel">
                                <Border Margin="0,4,0,6"
                                        Padding="12"
                                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12">
                                    <StackPanel Spacing="4">
                                        <TextBlock FontWeight="SemiBold" Text="{x:Bind FileName}" />
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="WrapWholeWords" Text="{x:Bind SourceSummary}" />
                                        <StackPanel Orientation="Horizontal" Spacing="10">
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind CreatedAtText}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind DurationText}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind QualityPreset}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind MediaFlagsText}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind FileSizeText}" />
                                            <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind AvailabilityText}" />
                                        </StackPanel>
                                        <TextBlock Foreground="IndianRed" Text="{x:Bind FailureText}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                        <Button MinHeight="40" Padding="16,10" CornerRadius="12" Command="{x:Bind ViewModel.OpenRecordingCommand}" Content="Open File" />
                        <Button MinHeight="40" Padding="16,10" CornerRadius="12" Command="{x:Bind ViewModel.OpenContainingFolderCommand}" Content="Open Folder" />
                        <Button MinHeight="40" Padding="16,10" CornerRadius="12" Command="{x:Bind ViewModel.CopyPathCommand}" Content="Copy Path" />
                        <Button MinHeight="40" Padding="16,10" CornerRadius="12" Command="{x:Bind ViewModel.RemoveHistoryItemCommand}" Content="Remove" />
                        <Button MinHeight="40" Padding="16,10" CornerRadius="12" Command="{x:Bind ViewModel.ClearMissingHistoryCommand}" Content="Clear Missing" />
                        <Button MinHeight="40" Padding="16,10" CornerRadius="12" Command="{x:Bind ViewModel.ClearAllHistoryCommand}" Content="Clear All" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>

