<Window
    x:Class="ScreenFast.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:viewModels="using:ScreenFast.App.ViewModels"
    mc:Ignorable="d">

    <ScrollViewer>
        <Grid Padding="24" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="4">
                <TextBlock FontSize="28" FontWeight="SemiBold" Text="ScreenFast" />
                <TextBlock Opacity="0.72" Text="Native screen recording for everyday Windows use." />
            </StackPanel>

            <InfoBar Grid.Row="1"
                     IsOpen="{x:Bind ViewModel.IsOnboardingVisible, Mode=OneWay}"
                     Severity="Informational"
                     IsClosable="False"
                     Message="Quick start: select a source, choose an output folder, choose your audio and quality options, then record and stop to finalize MP4.">
                <InfoBar.ActionButton>
                    <Button Command="{x:Bind ViewModel.DismissOnboardingCommand}" Content="Got it" />
                </InfoBar.ActionButton>
            </InfoBar>

            <InfoBar Grid.Row="2"
                     Title="Previous recording may have ended unexpectedly"
                     IsOpen="{x:Bind ViewModel.IsRecoveryNoticeVisible, Mode=OneWay}"
                     Severity="Warning"
                     IsClosable="False"
                     Message="{x:Bind ViewModel.RecoveryNoticeText, Mode=OneWay}">
                <InfoBar.ActionButton>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Command="{x:Bind ViewModel.OpenRecoveryFolderCommand}" Content="Open Folder" />
                        <Button Command="{x:Bind ViewModel.CopyRecoveryPathCommand}" Content="Copy Path" />
                        <Button Command="{x:Bind ViewModel.ClearRecoveryStateCommand}" Content="Clear" />
                        <Button Command="{x:Bind ViewModel.DismissRecoveryNoticeCommand}" Content="Dismiss" />
                    </StackPanel>
                </InfoBar.ActionButton>
            </InfoBar>

            <Grid Grid.Row="3" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button MinWidth="180"
                        Command="{x:Bind ViewModel.SelectSourceCommand}"
                        Content="Select Source" />

                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock FontWeight="SemiBold" Text="{x:Bind ViewModel.SourceSummary, Mode=OneWay}" />
                    <TextBlock Opacity="0.72" Text="{x:Bind ViewModel.SourceDetails, Mode=OneWay}" />
                    <TextBlock Opacity="0.72" Text="{x:Bind ViewModel.SourceIdText, Mode=OneWay}" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="4" ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button MinWidth="180"
                        Command="{x:Bind ViewModel.PickOutputFolderCommand}"
                        Content="Choose Output Folder" />

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           Opacity="0.72"
                           Text="{x:Bind ViewModel.OutputFolderText, Mode=OneWay}" />
            </Grid>

            <Border Grid.Row="5"
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                <StackPanel Spacing="12">
                    <TextBlock FontWeight="SemiBold" Text="Recording Setup" />
                    <Grid ColumnSpacing="12" RowSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock VerticalAlignment="Center" FontWeight="SemiBold" Text="Quality" />
                        <ComboBox Grid.Column="1"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{x:Bind ViewModel.QualityPresets, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedQualityPreset, Mode=TwoWay}" />
                        <ToggleSwitch Grid.Column="2"
                                      Header="System Audio"
                                      IsOn="{x:Bind ViewModel.IncludeSystemAudio, Mode=TwoWay}" />
                        <ToggleSwitch Grid.Column="3"
                                      Header="Microphone"
                                      IsOn="{x:Bind ViewModel.IncludeMicrophone, Mode=TwoWay}" />

                        <TextBlock Grid.Row="1" VerticalAlignment="Center" FontWeight="SemiBold" Text="After Recording" />
                        <ComboBox Grid.Row="1"
                                  Grid.Column="1"
                                  DisplayMemberPath="Label"
                                  ItemsSource="{x:Bind ViewModel.PostRecordingBehaviors, Mode=OneWay}"
                                  SelectedItem="{x:Bind ViewModel.SelectedPostRecordingBehavior, Mode=TwoWay}" />
                        <Button Grid.Row="1"
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Command="{x:Bind ViewModel.ShowOnboardingAgainCommand}"
                                Content="Show onboarding" />
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel Grid.Row="6" Orientation="Horizontal" Spacing="12">
                <Button MinWidth="120"
                        Command="{x:Bind ViewModel.RecordCommand}"
                        Content="Record" />
                <Button MinWidth="120"
                        Command="{x:Bind ViewModel.PauseResumeCommand}"
                        Content="{x:Bind ViewModel.PauseResumeText, Mode=OneWay}" />
                <Button MinWidth="120"
                        Command="{x:Bind ViewModel.StopCommand}"
                        Content="Stop" />
                <Border Padding="8"
                        CornerRadius="6"
                        Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                    <StackPanel Spacing="2">
                        <TextBlock FontWeight="SemiBold" Text="Ready check" />
                        <TextBlock Opacity="0.82" Text="{x:Bind ViewModel.ReadySourceText, Mode=OneWay}" />
                        <TextBlock Opacity="0.82" Text="{x:Bind ViewModel.ReadyOutputFolderText, Mode=OneWay}" />
                        <TextBlock Opacity="0.82" Text="{x:Bind ViewModel.AudioChoicesSummary, Mode=OneWay}" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <Grid Grid.Row="7" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock FontWeight="SemiBold"
                           Text="{x:Bind ViewModel.StatusText, Mode=OneWay}"
                           TextWrapping="WrapWholeWords" />
                <TextBlock Grid.Column="1"
                           FontFamily="Consolas"
                           Text="{x:Bind ViewModel.TimerText, Mode=OneWay}" />
            </Grid>

            <Grid Grid.Row="8" ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock FontWeight="SemiBold" Text="Startup and Tray" />
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <ToggleSwitch Header="Launch Minimized"
                                          IsOn="{x:Bind ViewModel.LaunchMinimizedToTray, Mode=TwoWay}" />
                            <ToggleSwitch Header="Close To Tray"
                                          IsOn="{x:Bind ViewModel.CloseToTray, Mode=TwoWay}" />
                            <ToggleSwitch Header="Minimize To Tray"
                                          IsOn="{x:Bind ViewModel.MinimizeToTray, Mode=TwoWay}" />
                        </StackPanel>
                        <TextBlock Opacity="0.72" Text="{x:Bind ViewModel.StateText, Mode=OneWay}" />
                        <TextBlock Opacity="0.72"
                                   Text="{x:Bind ViewModel.ShellMessageText, Mode=OneWay}"
                                   TextWrapping="WrapWholeWords" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button Command="{x:Bind ViewModel.ExportDiagnosticsCommand}" Content="Export Diagnostics" />
                            <TextBlock VerticalAlignment="Center"
                                       Opacity="0.72"
                                       Text="Exports recent logs and safe app metadata into a zip file." />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Padding="16"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        CornerRadius="8">
                    <StackPanel Spacing="12">
                        <TextBlock FontWeight="SemiBold" Text="Hotkeys" />
                        <Grid ColumnSpacing="12" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="160" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="140" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock VerticalAlignment="Center" Text="Start Recording" />
                            <ComboBox Grid.Column="1"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.HotkeyModifiers, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.StartHotkeyModifier, Mode=TwoWay}" />
                            <ComboBox Grid.Column="2"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.HotkeyKeys, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.StartHotkeyKey, Mode=TwoWay}" />

                            <TextBlock Grid.Row="1" VerticalAlignment="Center" Text="Stop Recording" />
                            <ComboBox Grid.Row="1"
                                      Grid.Column="1"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.HotkeyModifiers, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.StopHotkeyModifier, Mode=TwoWay}" />
                            <ComboBox Grid.Row="1"
                                      Grid.Column="2"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.HotkeyKeys, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.StopHotkeyKey, Mode=TwoWay}" />

                            <TextBlock Grid.Row="2" VerticalAlignment="Center" Text="Pause / Resume" />
                            <ComboBox Grid.Row="2"
                                      Grid.Column="1"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.HotkeyModifiers, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.PauseHotkeyModifier, Mode=TwoWay}" />
                            <ComboBox Grid.Row="2"
                                      Grid.Column="2"
                                      DisplayMemberPath="Label"
                                      ItemsSource="{x:Bind ViewModel.HotkeyKeys, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.PauseHotkeyKey, Mode=TwoWay}" />
                        </Grid>

                        <Button Width="140"
                                Command="{x:Bind ViewModel.ApplyHotkeysCommand}"
                                Content="Apply Hotkeys" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="9"
                    Padding="16"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8">
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock FontWeight="SemiBold" Text="Recent Recordings" />
                    <TextBlock Grid.Row="1"
                               Opacity="0.72"
                               Text="{x:Bind ViewModel.RecentRecordingsStatusText, Mode=OneWay}" />

                    <ListView Grid.Row="2"
                              MinHeight="240"
                              ItemsSource="{x:Bind ViewModel.RecentRecordings, Mode=OneWay}"
                              SelectedItem="{x:Bind ViewModel.SelectedRecentRecording, Mode=TwoWay}">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="viewModels:RecordingHistoryItemViewModel">
                                <StackPanel Spacing="2" Margin="0,2,0,6">
                                    <TextBlock FontWeight="SemiBold" Text="{x:Bind FileName}" />
                                    <TextBlock Opacity="0.72" Text="{x:Bind SourceSummary}" />
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <TextBlock Opacity="0.72" Text="{x:Bind CreatedAtText}" />
                                        <TextBlock Opacity="0.72" Text="{x:Bind DurationText}" />
                                        <TextBlock Opacity="0.72" Text="{x:Bind QualityPreset}" />
                                        <TextBlock Opacity="0.72" Text="{x:Bind MediaFlagsText}" />
                                        <TextBlock Opacity="0.72" Text="{x:Bind FileSizeText}" />
                                        <TextBlock Opacity="0.72" Text="{x:Bind AvailabilityText}" />
                                    </StackPanel>
                                    <TextBlock Foreground="IndianRed" Text="{x:Bind FailureText}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                        <Button Command="{x:Bind ViewModel.OpenRecordingCommand}" Content="Open File" />
                        <Button Command="{x:Bind ViewModel.OpenContainingFolderCommand}" Content="Open Folder" />
                        <Button Command="{x:Bind ViewModel.CopyPathCommand}" Content="Copy Path" />
                        <Button Command="{x:Bind ViewModel.RemoveHistoryItemCommand}" Content="Remove" />
                        <Button Command="{x:Bind ViewModel.ClearMissingHistoryCommand}" Content="Clear Missing" />
                        <Button Command="{x:Bind ViewModel.ClearAllHistoryCommand}" Content="Clear All" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
